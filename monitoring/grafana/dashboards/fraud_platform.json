{
  "uid": "fraud-platform-v1",
  "title": "Fraud Detection Platform",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Transacciones",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(fraud_scoring_requests_total)",
        "legendFormat": "Total"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Bloqueadas",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(fraud_scoring_requests_total{decision=\"BLOCK\"})",
        "legendFormat": "BLOCK"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "En Revisión",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(fraud_scoring_requests_total{decision=\"REVIEW\"})",
        "legendFormat": "REVIEW"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latencia p50 (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "ms"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.50, sum(rate(fraud_scoring_latency_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p50"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Latencia p99 (ms)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "ms"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.99, sum(rate(fraud_scoring_latency_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p99"
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Tasa de Bloqueo %",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(fraud_scoring_requests_total{decision=\"BLOCK\"}[5m])) / sum(rate(fraud_scoring_requests_total[5m])) * 100",
        "legendFormat": "Block rate"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Transacciones por Decisión (rate/min)",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "APPROVE" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00d4aa" } }] },
          { "matcher": { "id": "byName", "options": "REVIEW"  }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f39c12" } }] },
          { "matcher": { "id": "byName", "options": "BLOCK"   }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e74c3c" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(fraud_scoring_requests_total{decision=\"APPROVE\"}[1m]))",
          "legendFormat": "APPROVE"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(fraud_scoring_requests_total{decision=\"REVIEW\"}[1m]))",
          "legendFormat": "REVIEW"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(fraud_scoring_requests_total{decision=\"BLOCK\"}[1m]))",
          "legendFormat": "BLOCK"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Top Reglas Disparadas",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(7, sum by (rule) (rules_triggered_total))",
        "legendFormat": "{{rule}}"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Distribución de Scores (histograma percentiles)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 1, "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(fraud_score_distribution_bucket[5m])) by (le))",
          "legendFormat": "Score p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.90, sum(rate(fraud_score_distribution_bucket[5m])) by (le))",
          "legendFormat": "Score p90"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(fraud_score_distribution_bucket[5m])) by (le))",
          "legendFormat": "Score p99"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Latencia de Scoring (percentiles)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(fraud_scoring_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(fraud_scoring_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(fraud_scoring_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
